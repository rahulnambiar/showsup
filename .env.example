# ── Mode ──────────────────────────────────────────────────────────────────────
# selfhost (default): all features free, no token system
# cloud: token system active, requires Stripe keys below
NEXT_PUBLIC_MODE=selfhost

# ── LLM Providers — at least one required ────────────────────────────────────
# Missing keys are skipped with a console warning; everything still works.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ── Supabase — required ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for npm run db:setup (optional — or use Supabase CLI)
# Find in: Supabase → Settings → Database → Connection string
# SUPABASE_DB_URL=postgres://postgres:[password]@[host]:5432/postgres

# ── Email (Resend) — optional ─────────────────────────────────────────────────
# Without this, signup emails are sent by Supabase's default mailer
RESEND_API_KEY=
RESEND_FROM_EMAIL=ShowsUp <noreply@yourdomain.com>

# ── Analytics (PostHog) — optional ───────────────────────────────────────────
# Silently disabled if unset
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Google Search Console OAuth — optional ────────────────────────────────────
# Required only if you want users to connect their GSC accounts for correlation data
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Enable: Google Search Console API + OAuth consent screen (scope: webmasters.readonly)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google-gsc/callback

# ── Stripe — cloud mode only ──────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

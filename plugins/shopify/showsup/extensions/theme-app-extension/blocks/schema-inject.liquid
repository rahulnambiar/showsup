{% comment %}
  ShowsUp Schema Injection Block
  ─────────────────────────────────────────────────────────────────
  App embed block — runs on every page of the storefront.
  Injects:
    1. Organization schema (sitewide)
    2. Product schema (product pages only)
    3. FAQPage schema (if FAQ data stored in metafield)
    4. BreadcrumbList (collection/product pages)

  Settings are defined below and configurable in Theme Editor.
{% endcomment %}

{% if block.settings.enabled %}

{%- assign org_name = block.settings.org_name | default: shop.name -%}
{%- assign org_url  = shop.url -%}

{%- comment -%} 1. Organization schema — every page {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ org_name | json }},
  "url": {{ org_url | json }},
  {%- if block.settings.description != blank -%}
  "description": {{ block.settings.description | json }},
  {%- elsif shop.description != blank -%}
  "description": {{ shop.description | json }},
  {%- endif -%}
  {%- assign same_as = "" -%}
  {%- if block.settings.twitter_url != blank -%}
    {%- assign same_as = same_as | append: block.settings.twitter_url | append: "|" -%}
  {%- endif -%}
  {%- if block.settings.linkedin_url != blank -%}
    {%- assign same_as = same_as | append: block.settings.linkedin_url | append: "|" -%}
  {%- endif -%}
  {%- if block.settings.facebook_url != blank -%}
    {%- assign same_as = same_as | append: block.settings.facebook_url | append: "|" -%}
  {%- endif -%}
  {%- if block.settings.instagram_url != blank -%}
    {%- assign same_as = same_as | append: block.settings.instagram_url | append: "|" -%}
  {%- endif -%}
  {%- if same_as != blank -%}
    {%- assign same_as_arr = same_as | split: "|" -%}
  "sameAs": [
    {%- for s in same_as_arr -%}
      {%- if s != blank -%}
        {{ s | json }}{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ],
  {%- endif -%}
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "url": {{ org_url | append: "/pages/contact" | json }}
  }
}
</script>

{%- comment -%} 2. Product schema — product pages only {%- endcomment -%}
{%- if template.name == "product" and product -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "url": {{ canonical_url | json }},
  {%- if product.selected_or_first_available_variant.sku != blank -%}
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  {%- endif -%}
  {%- if product.vendor != blank -%}
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  {%- endif -%}
  {%- if product.featured_image -%}
  "image": [
    {%- for image in product.images limit: 3 -%}
      {{ image | image_url: width: 1200 | prepend: "https:" | json }}{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ],
  {%- endif -%}
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "lowPrice": {{ product.price_min | divided_by: 100.0 }},
    "highPrice": {{ product.price_max | divided_by: 100.0 }},
    "offerCount": {{ product.variants.size }},
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
    "url": {{ canonical_url | json }},
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    }
  }
  {%- if product.metafields.reviews.rating.value -%}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ product.metafields.reviews.rating.value }},
    "reviewCount": {{ product.metafields.reviews.rating_count.value | default: 0 }}
  }
  {%- endif -%}
}
</script>

{%- comment -%} Product breadcrumb {%- endcomment -%}
{%- if collection -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": {{ shop.url | json }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": {{ shop.url | append: collection.url | json }}
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": {{ canonical_url | json }}
    }
  ]
}
</script>
{%- endif -%}
{%- endif -%}

{%- comment -%} 3. Collection schema — collection pages {%- endcomment -%}
{%- if template.name == "collection" and collection -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": {{ collection.title | json }},
  "url": {{ canonical_url | json }}
  {%- if collection.description != blank -%}
  ,"description": {{ collection.description | strip_html | truncate: 500 | json }}
  {%- endif -%}
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",                             "item": {{ shop.url | json }} },
    { "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ canonical_url | json }} }
  ]
}
</script>
{%- endif -%}

{%- comment -%} 4. FAQ schema from metafield (populated by ShowsUp app) {%- endcomment -%}
{%- assign faq_meta = shop.metafields.showsup.faq_schema -%}
{%- if faq_meta != blank -%}
<script type="application/ld+json">
{{ faq_meta }}
</script>
{%- endif -%}

{% endif %}

{% schema %}
{
  "name": "ShowsUp Schema",
  "target": "head",
  "settings": [
    {
      "type":    "checkbox",
      "id":      "enabled",
      "label":   "Enable schema injection",
      "default": true
    },
    {
      "type":    "text",
      "id":      "org_name",
      "label":   "Organization name",
      "info":    "Defaults to shop name if blank."
    },
    {
      "type":    "textarea",
      "id":      "description",
      "label":   "Store description",
      "info":    "Used in Organization schema. Defaults to shop description."
    },
    {
      "type":  "header",
      "content": "Social Profiles (for sameAs)"
    },
    { "type": "url", "id": "twitter_url",   "label": "Twitter / X URL"  },
    { "type": "url", "id": "linkedin_url",  "label": "LinkedIn URL"     },
    { "type": "url", "id": "facebook_url",  "label": "Facebook URL"     },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL"    }
  ]
}
{% endschema %}

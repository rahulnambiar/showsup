SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_APP_URL=https://your-tunnel-url.trycloudflare.com
SCOPES=read_products,read_product_listings,read_collections,read_content,read_themes,read_orders,read_customers,write_script_tags,read_price_rules,read_metafields,write_metafields

# SQLite database (for development)
DATABASE_URL=file:./prisma/dev.db

# Optional: default ShowsUp API token for all stores (or per-store via Settings)
SHOWSUP_API_TOKEN=

# Optional: self-hosted ShowsUp backend URL
SHOWSUP_CLOUD_URL=https://showsup.co
